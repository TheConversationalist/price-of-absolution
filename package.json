{
  "name": "price-of-absolution",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "book-projection",
    "tablet-controller",
    "sync-server"
  ],
  "scripts": {
    "dev:book": "npm --workspace book-projection run dev",

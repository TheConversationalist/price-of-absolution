{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StorySceneGraph",
  "type": "object",
  "required": ["title", "startSceneId", "scenes"],
  "properties": {
    "title": { "type": "string" },
    "startSceneId": { "type": "string" },
    "scenes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "sceneId",
          "displayText",
          "choices",
          "timeoutSeconds",
          "onTimeout"
        ],
        "properties": {
          "sceneId": { "type": "string" },
          "displayText": { "type": "string" },
          "narrationAudio": { "type": "string" },
          "backgroundVideo": { "type": "string" },
          "ambientSfx": { "type": "string" },
          "soundtrack": { "type": "string" },
          "timeoutSeconds": { "type": "number", "minimum": 1 },
          "choicesRevealSecondsBeforeEnd": {
            "type": "number",
            "minimum": 1,
            "description": "Show branch choices only when this many seconds or fewer remain in the scene (see timeoutSeconds)."
          },
          "onTimeout": { "type": "string" },
          "holdFirstFrame": {
            "type": "boolean",
            "description": "Book: show frame 0 of backgroundVideo and do not play until the next scene load."
          },
          "hideTabletTimer": {
            "type": "boolean",
            "description": "Tablet: no countdown bar; branch choices available immediately."
          },
          "nextSceneId": {
            "type": "string",
            "description": "When choices is empty, the book advances here after the clip ends (or as the primary linear edge)."
          },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label", "targetSceneId"],
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "targetSceneId": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
